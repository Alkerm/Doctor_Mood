# Flask / Session security
FLASK_SECRET_KEY=replace_with_long_random_secret
SESSION_COOKIE_SECURE=true

# Auth & usage controls
ADMIN_API_KEY=replace_with_admin_secret
DEFAULT_TRIALS=0
# If relative, path is resolved from project directory (or RENDER_DISK_PATH on Render if set)
DB_PATH=app.db

# Google Gemini / Nano Banana (default app face generation flow)
GEMINI_API_KEY=your_gemini_api_key_here

# Replicate (optional fallback for legacy face swap models)
REPLICATE_API_TOKEN=your_replicate_token_here
# Face swap model selection
# Supported: yan-ops/face_swap, codeplugtech/face-swap, google/nano-banana, google/nano-banana-pro
FACE_SWAP_MODEL=google/nano-banana
# Optional fallback if primary model fails
FACE_SWAP_FALLBACK_MODEL=
# Keep paid Gemini generation attempts to one by default. Increase only if you accept retry costs.
GOOGLE_DIRECT_MAX_ATTEMPTS=1
# Face swap tuning (0.5 to 1.0, lower = subtler blend, higher = stronger face transfer)
FACE_SWAP_WEIGHT=0.85
# Optional per-character overrides: character=weight pairs separated by commas
# Example: FACE_SWAP_WEIGHT_OVERRIDES=doctor_boy=0.82,teacher_girl=0.84,default=0.85
FACE_SWAP_WEIGHT_OVERRIDES=

# Cloudinary (required by app face generation flow)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: for helper scripts only. app.py also accepts this if GEMINI_API_KEY is not set.
GOOGLE_API_KEY=your_google_api_key_here

# Runtime
PORT=5000
